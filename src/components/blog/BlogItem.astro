---
import CategoryTags from "../_globals/articles/CategoryTags.astro";

export interface Props {
  url: string;
  content: {
    id: string;
    title: string;
    description: string;
    date: string;
    categories: string[];
  };
}

const {
  url,
  content: { id, title, description, date, categories },
} = Astro.props as Props;
---

<li id={`blog-${id}`} box-="square" class="p-4 mb-4">
  <div class="flex justify-between items-start gap-4 mb-2">
    <a href={url} class="text-term-accent hover:underline font-semibold">
      {title}
    </a>
    <span class="text-term-muted flex-shrink-0 text-sm">{date}</span>
  </div>

  <CategoryTags categories={categories} />

  <div class="mt-3 text-term-dim">
    <p>{description}</p>
  </div>
</li>
