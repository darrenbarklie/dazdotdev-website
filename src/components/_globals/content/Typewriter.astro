---
interface Props {
  text: string;
  speed?: number;
  delay?: number;
}

const { text, speed = 30, delay = 0 } = Astro.props;
---
<div class="typewriter" data-text={text} data-speed={speed} data-delay={delay}>
  <span class="typewriter-content"></span>
  <span class="typewriter-cursor">▋</span>
</div>
