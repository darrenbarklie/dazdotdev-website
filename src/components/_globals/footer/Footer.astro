---
const currentDate = new Date();
const currentYear = new Date().getFullYear();
---

<footer id="footer" class="mt-16 mb-8">
  <div class="container">
    <div box-="square" class="px-4 py-3">
      <div class="flex justify-between items-center">
        <div id="copyright" class="text-sm">
          <span class="text-gray-500">#</span> &copy; {currentYear} Darren Barklie
        </div>
        <div class="flex gap-4 text-sm">
          <a href="/privacy" class="no-underline hover:bg-white/10 px-2 py-1">[privacy]</a>
        </div>
      </div>
      <div class="mt-2 text-xs opacity-50">
        <span class="text-green-500">$</span> rendered {currentDate.toISOString()}
      </div>
    </div>
  </div>
</footer>
