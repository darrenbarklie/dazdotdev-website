---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
const currentPath = Astro.url.pathname;
const isActive = currentPath.startsWith(url) && url !== "/";
---

<a
  href={url}
  class:list={[
    "px-3 py-1 no-underline",
    isActive ? "bg-white text-black" : "hover:bg-white/10"
  ]}
>
  [{title.toLowerCase()}]
</a>
