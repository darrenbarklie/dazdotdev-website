---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
const currentPath = Astro.url.pathname;
const isActive = currentPath.startsWith(url) && url !== "/";
---

<a
  href={url}
  class:list={[
    "px-3 py-1 no-underline",
    isActive ? "text-term-bg bg-term-fg" : "text-term hover:text-term-bright"
  ]}
  style={isActive ? "background: var(--term-fg); color: var(--term-bg);" : ""}
>
  [{title.toLowerCase()}]
</a>
