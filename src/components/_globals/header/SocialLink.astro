---
interface Props {
  title: string;
  url: string;
  img: string;
}

const { title, url } = Astro.props;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="social-link px-2 py-1 no-underline transition-colors"
>
  [@{title.toLowerCase()}]
</a>

<style>
  .social-link {
    color: var(--term-fg-dim);
  }
  .social-link:hover {
    color: var(--term-fg-bright);
  }
  .social-link:active {
    color: var(--term-fg);
  }
</style>
