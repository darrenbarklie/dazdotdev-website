---
import NavLink from "./NavLink.astro";
import SocialLink from "./SocialLink.astro";
---

<nav class="flex items-center gap-1" aria-labelledby="primary-navigation">
  <h2 id="primary-navigation" class="sr-only">Primary Navigation</h2>
  {
    [
      ["About", "/about"],
      ["Work", "/work"],
      ["Blog", "/blog"],
      ["Bookmarks", "/bookmarks"],
    ].map(([title, url]) => (
      <NavLink title={title} url={url} />
    ))
  }
  <span class="mx-2 opacity-50">|</span>
  <SocialLink
    title="x"
    url="https://x.com/dazdotdev"
    img="/svg/logo-social-twitter.svg"
  />
</nav>
