---
import CategoryTags from "../_globals/articles/CategoryTags.astro";

export interface Props {
  content: {
    id: string;
    client: string;
    date: string;
    location: string;
    tech: string[];
    roles: string[];
    urls: URL[] | string;
    blurb: string;
  };
}

const {
  content: { id, client, date, location, tech, roles, urls, blurb },
} = Astro.props as Props;
---

<li id={`work-${id}`} box-="square" class="p-4 mb-4">
  <div class="flex justify-between items-start gap-4 mb-3">
    <h3 class="text-lg font-semibold" style="color: var(--foreground1);">{client}</h3>
    <span class="flex-shrink-0 text-sm" style="color: var(--foreground2);">#{id}</span>
  </div>

  <div class="flex flex-wrap justify-between gap-4 mb-3 text-sm">
    <div class="space-y-2">
      <div style="color: var(--foreground1);">
        <span style="color: var(--foreground0); font-weight: 600;">{date}</span>
        <span class="mx-2">|</span>
        <span>{location}</span>
      </div>

      {urls && Object.values(urls).length > 0 && (
        <div class="space-y-1">
          {Object.values(urls).map((item) => (
            <a href={item} rel="noopener noreferrer" target="_blank" class="block hover:underline text-xs" style="color: var(--foreground1);">
              → {item}
            </a>
          ))}
        </div>
      )}

      <CategoryTags categories={tech} />
    </div>

    <div class="text-right">
      {Object.values(roles).map((item) => (
        <div style="color: var(--foreground1);">{item}</div>
      ))}
    </div>
  </div>

  <p style="color: var(--foreground1);">{blurb}</p>
</li>
