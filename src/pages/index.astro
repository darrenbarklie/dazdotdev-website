---
import Layout from "../layouts/Layout.astro";

const title = "Home";
---

<Layout title={title}>
  <main>
    <div box-="square" class="p-6">
      <div class="mb-4">
        <span class="typing-command" style="color: var(--foreground0);">$ whoami</span>
      </div>
      <div class="space-y-2 pl-4 reveal-lines">
        <p class="reveal-line"><span style="color: var(--foreground1);">→</span> Technical founder</p>
        <p class="reveal-line"><span style="color: var(--foreground1);">→</span> Building businesses and technology platforms</p>
        <p class="reveal-line">
          <span style="color: var(--foreground1);">→</span> Learning in public as I move deeper into AI-assisted software, data, and machine learning
        </p>
        <p class="reveal-line"><span style="color: var(--foreground1);">→</span> Available for platform, product, and AI-assisted software work</p>
        <p class="reveal-line"><span style="color: var(--foreground1);">→</span> Currently based on Isle of Man</p>
        <p class="reveal-line"><span style="color: var(--foreground1);">→</span> Nerd for guitar, drums & synth sounds</p>
      </div>
    </div>
  </main>
</Layout>

<style>
  .typing-command {
    display: inline-block;
    clip-path: inset(0 100% 0 0);
    animation: type-command 0.7s steps(8, end) 0.15s forwards;
    position: relative;
  }

  .typing-command::after {
    content: "";
    display: inline-block;
    width: 0.6ch;
    height: 1em;
    margin-left: 0.2ch;
    transform: translateY(0.15em);
    background: var(--foreground0);
    animation: cursor-blink 0.9s steps(1, end) 0.15s 3 forwards;
  }

  .reveal-line {
    opacity: 0;
    transform: translateY(0.35rem);
    animation: reveal-line 0.32s ease-out forwards;
  }

  .reveal-line:nth-child(1) {
    animation-delay: 0.95s;
  }

  .reveal-line:nth-child(2) {
    animation-delay: 1.08s;
  }

  .reveal-line:nth-child(3) {
    animation-delay: 1.21s;
  }

  .reveal-line:nth-child(4) {
    animation-delay: 1.34s;
  }

  .reveal-line:nth-child(5) {
    animation-delay: 1.47s;
  }

  .reveal-line:nth-child(6) {
    animation-delay: 1.6s;
  }

  @keyframes type-command {
    to {
      clip-path: inset(0 0 0 0);
    }
  }

  @keyframes cursor-blink {
    0%,
    49% {
      opacity: 1;
    }

    50%,
    100% {
      opacity: 0;
    }
  }

  @keyframes reveal-line {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .typing-command,
    .typing-command::after,
    .reveal-line {
      animation: none;
    }

    .typing-command {
      clip-path: none;
    }

    .typing-command::after {
      display: none;
    }

    .reveal-line {
      opacity: 1;
      transform: none;
    }
  }
</style>
