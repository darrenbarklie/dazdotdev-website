---
import Layout from "../layouts/Layout.astro";

const title = "Home";
---

<Layout title={title}>
  <main>
    <div box-="square" class="p-6">
      <div class="mb-4">
        <span style="color: var(--foreground0);">$ whoami</span>
      </div>
      <div class="space-y-2 pl-4">
        <p>
          <span style="color: var(--foreground1);">→</span> Founder of
          <a href="https://craftapplied.com" target="_blank" class="hover:underline" style="color: var(--foreground1);">Craft Applied</a>
          tech agency, est. 2018
        </p>
        <p><span style="color: var(--foreground1);">→</span> Full stack TypeScript developer</p>
        <p><span style="color: var(--foreground1);">→</span> Currently based on Isle of Man</p>
        <p>
          <span style="color: var(--foreground1);">→</span> Relapsing digital nomad:
        </p>
        <div class="pl-6 space-y-1" style="color: var(--foreground1);">
          <p><span style="color: var(--foreground2);">├─</span> London</p>
          <p><span style="color: var(--foreground2);">├─</span> New York City</p>
          <p><span style="color: var(--foreground2);">└─</span> Ho Chi Minh City</p>
        </div>
        <p><span style="color: var(--foreground1);">→</span> Nerd for guitar, drums & synth sounds</p>
      </div>
    </div>
  </main>
</Layout>
