---
import Layout from "../layouts/Layout.astro";

const title = "Home";
---

<Layout title={title}>
  <main>
    <div box-="square" class="p-6">
      <div class="mb-4">
        <span class="typing-command" style="color: var(--foreground0);" aria-label="$ whoami">
          <span class="typing-command-mask" aria-hidden="true">$ whoami</span>
        </span>
      </div>
      <div class="space-y-2 pl-4 reveal-lines">
        <p class="reveal-line"><span class="line-arrow">→</span><span>Technical founder building businesses and technology platforms</span></p>
        <p class="reveal-line"><span class="line-arrow">→</span><span>15+ years building web products, internal tools, platforms, and ecommerce</span></p>
        <p class="reveal-line"><span class="line-arrow">→</span><span>Across finance, education, health, construction, and local organisations</span></p>
        <p class="reveal-line">
          <span class="line-arrow">→</span><span>Learning in public as I move deeper into AI-assisted software, data, and machine learning</span>
        </p>
        <p class="reveal-line"><span class="line-arrow">→</span><span>Available for platform, product, and AI-assisted software work</span></p>
        <p class="reveal-line"><span class="line-arrow">→</span><span>Currently based on Isle of Man</span></p>
        <p class="reveal-line"><span class="line-arrow">→</span><span>Nerd for guitar, drums & synth sounds</span></p>
      </div>
    </div>
  </main>
</Layout>

<style>
  .typing-command {
    display: inline-block;
    position: relative;
    white-space: nowrap;
  }

  .typing-command-mask {
    display: inline-block;
    max-width: 0;
    overflow: hidden;
    vertical-align: bottom;
    animation: type-command 0.7s steps(8, end) 0.15s forwards;
  }

  .typing-command-mask::after {
    content: "";
    position: absolute;
    left: calc(100% + 0.2ch);
    bottom: 0.08em;
    width: 0.9ch;
    height: 1em;
    background: var(--foreground0);
    animation: cursor-blink 0.9s steps(1, end) 0.15s 3 forwards;
  }

  .reveal-line {
    display: grid;
    grid-template-columns: 2ch minmax(0, 1fr);
    column-gap: 1ch;
    opacity: 0;
    transform: translateY(0.35rem);
    animation: reveal-line 0.32s ease-out forwards;
  }

  .line-arrow {
    color: var(--foreground1);
  }

  .reveal-line:nth-child(1) {
    animation-delay: 1.25s;
  }

  .reveal-line:nth-child(2) {
    animation-delay: 1.38s;
  }

  .reveal-line:nth-child(3) {
    animation-delay: 1.51s;
  }

  .reveal-line:nth-child(4) {
    animation-delay: 1.64s;
  }

  .reveal-line:nth-child(5) {
    animation-delay: 1.77s;
  }

  .reveal-line:nth-child(6) {
    animation-delay: 1.9s;
  }

  .reveal-line:nth-child(7) {
    animation-delay: 2.03s;
  }

  @keyframes type-command {
    to {
      max-width: 8ch;
    }
  }

  @keyframes cursor-blink {
    0%,
    49% {
      opacity: 1;
    }

    50%,
    100% {
      opacity: 0;
    }
  }

  @keyframes reveal-line {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .typing-command-mask,
    .typing-command-mask::after,
    .reveal-line {
      animation: none;
    }

    .typing-command-mask {
      max-width: none;
    }

    .typing-command-mask::after {
      display: none;
    }

    .reveal-line {
      opacity: 1;
      transform: none;
    }
  }
</style>
