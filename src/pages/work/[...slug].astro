---
import { getCollection, render } from "astro:content";
import HtmlHead from "../../components/_globals/HtmlHead.astro";
import Header from "../../components/_globals/header/Header.astro";
import Footer from "../../components/_globals/footer/Footer.astro";

export async function getStaticPaths() {
  const items = await getCollection("work");
  return items.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
---

<!DOCTYPE html>
<html lang="en">
  <HtmlHead title={item.data.client} />

  <body>
    <Header />

    <div class="container outer">
      <article class="prose prose-base">
        <header box-="square" class="p-4 mb-8">
          <div class="mb-2">
            <span class="text-cyan-400">$ cat</span>
            <span class="text-gray-400 ml-2">./work/{item.id}</span>
          </div>
          <h1 class="!mt-2 !mb-2">{item.data.client}</h1>
          <div class="text-sm text-gray-400">
            <span class="text-yellow-500">{item.data.date}</span>
            <span class="mx-2">|</span>
            <span>{item.data.location}</span>
          </div>
        </header>

        <Content />
      </article>
    </div>

    <Footer />
  </body>
</html>
