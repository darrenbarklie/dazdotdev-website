---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import WorkItem from "../../components/work/WorkItem.astro";

const work = await getCollection("work");
---

<Layout title="Work History">
  <div class="mb-6">
    <span class="text-cyan-400">$ ls -la ./work</span>
    <span class="text-gray-500 ml-4"># {work.length} projects</span>
  </div>
  <ul class="space-y-4">
    {work.map((item) => <WorkItem content={item.data} />)}
  </ul>
</Layout>
