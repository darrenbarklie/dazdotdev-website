---
import { getCollection, render } from "astro:content";
import HtmlHead from "../../components/_globals/HtmlHead.astro";
import Header from "../../components/_globals/header/Header.astro";
import Footer from "../../components/_globals/footer/Footer.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const objectDate = new Date(post.data.date);
const [day, month, year] = [
  objectDate.getDate(),
  objectDate.toLocaleString("default", { month: "long" }),
  objectDate.getFullYear(),
];
---

<!DOCTYPE html>
<html lang="en">
  <HtmlHead title={post.data.title} />

  <body>
    <Header />

    <div class="container outer">
      <article class="prose prose-base">
        <header box-="square" class="p-4 mb-8">
          <div class="mb-2">
            <span class="text-cyan-400">$ cat</span>
            <span class="text-gray-400 ml-2">./blog/{post.id}</span>
          </div>
          <h1 class="!mt-2 !mb-2">{post.data.title}</h1>
          <div class="text-gray-500 text-sm">
            <span class="text-green-500">#</span> {day} {month} {year}
          </div>
        </header>

        <div id="excerpt" class="text-lg opacity-80 mb-6 pl-4 border-l-2 border-cyan-400">
          {post.data.description}
        </div>

        <Content />
      </article>
    </div>

    <Footer />
  </body>
</html>
