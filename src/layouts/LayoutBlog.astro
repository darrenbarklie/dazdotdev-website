---
import HtmlHead from "../components/_globals/HtmlHead.astro";
import Header from "../components/_globals/header/Header.astro";
import Footer from "../components/_globals/footer/Footer.astro";
import PageTransition from "../components/solid/PageTransition.tsx";

export interface Props {
  content: {
    title: string;
    date: string;
    excerpt: string;
    categories: string[];
  };
}

const {
  content: { title, date, excerpt },
} = Astro.props as Props;

const objectDate = new Date(date);
const [day, month, year] = [
  objectDate.getDate(),
  objectDate.toLocaleString("default", { month: "long" }),
  objectDate.getFullYear(),
];
---

<!DOCTYPE html>
<html lang="en">
  <HtmlHead title={title} />

  <body>
    <PageTransition client:load />
    <Header />

    <div class="container outer">
      <article class="prose prose-base">
        <header box-="square" class="p-4 mb-8">
          <div class="mb-2">
            <span class="text-term">$ cat</span>
            <span class="text-term-muted ml-2">./blog</span>
          </div>
          <h1 class="sr-only">{title}</h1>
          <div class="text-term-bright text-lg mb-2">{title}</div>
          <div class="text-term-muted text-sm">
            <span class="text-term-dim">#</span> {day} {month} {year}
          </div>
        </header>

        <div id="excerpt" class="text-lg text-term-dim mb-6 pl-4 border-l-2 border-term">
          {excerpt}
        </div>

        <slot />
      </article>
    </div>

    <Footer />
  </body>
</html>
