---
import HtmlHead from "../components/_globals/HtmlHead.astro";
import Header from "../components/_globals/header/Header.astro";
import Footer from "../components/_globals/footer/Footer.astro";
import PageTitle from "../components/_globals/page/PageTitle.astro";
import { ViewTransitions } from 'astro:transitions';

export interface Props {
  title: string;
}

const { title } = Astro.props as Props;
---

<!DOCTYPE html>
<html lang="en">
  <HtmlHead title={title} />
  <ViewTransitions />

  <body>
    <div id="scramble-overlay" class="scramble-overlay"></div>
    <Header />

    <div class="terminal-container outer">
      <PageTitle title={title} />
      <slot />
    </div>

    <Footer />

    <script>
      const glyphs = '!@#$%^&*()_+-=[]{}|;:\',.<>?/\\`~0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz';
      
      function getRandomGlyph() {
        return glyphs[Math.floor(Math.random() * glyphs.length)];
      }
      
      function generateRandomLines(count: number, length: number = 60) {
        const lines = [];
        for (let i = 0; i < count; i++) {
          let line = '';
          for (let j = 0; j < length; j++) {
            line += Math.random() > 0.3 ? getRandomGlyph() : ' ';
          }
          lines.push(line);
        }
        return lines;
      }
      
      let intervalId: number | undefined;
      const overlay = document.getElementById('scramble-overlay');
      
      function startScramble(phaseType: 'out' | 'in') {
        if (!overlay) return;
        
        overlay.style.display = 'flex';
        overlay.style.opacity = '1';
        
        let frame = 0;
        const maxFrames = phaseType === 'out' ? 8 : 12;
        
        function animate() {
          frame++;
          
          if (phaseType === 'out') {
            const lineCount = Math.max(1, Math.floor(15 * (1 - frame / maxFrames)));
            overlay.innerHTML = generateRandomLines(lineCount).map(line => 
              `<div style="opacity: ${1 - (frame / maxFrames) * 0.5}; white-space: pre;">${line}</div>`
            ).join('');
          } else {
            const progress = frame / maxFrames;
            if (progress < 0.7) {
              const lineCount = Math.floor(15 * (progress / 0.7));
              overlay.innerHTML = generateRandomLines(lineCount).map(line => 
                `<div style="opacity: ${0.3 + (frame / maxFrames) * 0.4}; white-space: pre;">${line}</div>`
              ).join('');
            } else {
              const lineCount = Math.max(0, Math.floor(15 * (1 - (progress - 0.7) / 0.3)));
              overlay.innerHTML = generateRandomLines(lineCount).map(line => 
                `<div style="opacity: ${1 - (progress - 0.7) / 0.3}; white-space: pre;">${line}</div>`
              ).join('');
            }
          }
          
          if (frame < maxFrames) {
            intervalId = setTimeout(animate, 40);
          } else {
            if (phaseType === 'in') {
              overlay.style.opacity = '0';
              setTimeout(() => {
                overlay.style.display = 'none';
                overlay.innerHTML = '';
              }, 150);
            } else {
              overlay.style.opacity = '0';
              setTimeout(() => {
                overlay.style.display = 'none';
                overlay.innerHTML = '';
              }, 150);
            }
          }
        }
        
        animate();
      }
      
      document.addEventListener('astro:before-preparation', () => {
        startScramble('out');
      });
      
      document.addEventListener('astro:after-swap', () => {
        startScramble('in');
      });
      
      document.addEventListener('astro:page-load', () => {
        if (overlay) {
          overlay.style.display = 'none';
          overlay.innerHTML = '';
        }
        initTypewriters();
      });
    </script>

    <script is:inline>
      // Global typewriter effect - single cursor writes entire page
      document.addEventListener('astro:page-load', () => {
        initGlobalTypewriter();
      });

      function initGlobalTypewriter() {
        if (document.querySelector('.global-typewriter-active')) return;
        document.body.classList.add('global-typewriter-active');

        const contentAreas = document.querySelectorAll('.terminal-container > main, .terminal-container > article, .prose');
        if (contentAreas.length === 0) return;

        const targets = contentAreas[0].querySelectorAll('h1, h2, h3, p, li, blockquote');
        const elements = [];
        const fullText = [];

        // Collect elements and their text
        targets.forEach(el => {
          const text = el.textContent?.trim();
          if (!text || text.length === 0 || text.length > 1000) return;

          const revealSpan = document.createElement('span');
          revealSpan.className = 'typewriter-reveal';
          revealSpan.dataset.fullText = text;
          revealSpan.dataset.revealed = '0';
          revealSpan.style.opacity = '0';
          el.replaceWith(revealSpan);

          elements.push(revealSpan);
          fullText.push(...text.split(''));
        });

        if (elements.length === 0) return;

        // Create single global cursor
        const cursor = document.createElement('span');
        cursor.className = 'global-typewriter-cursor';
        cursor.textContent = '▋';

        // Insert cursor after first element
        elements[0].parentNode.insertBefore(cursor, elements[0].nextSibling);

        // Animation
        let index = 0;
        const speed = 30;
        const textLength = fullText.length;

        function type() {
          if (index < textLength) {
            // Find which element this character belongs to
            let charCount = 0;
            for (const el of elements) {
              const elLength = el.dataset.fullText.length;
              if (index < charCount + elLength) {
                // This character belongs to this element
                const elIndex = index - charCount;
                const revealed = parseInt(el.dataset.revealed);
                if (elIndex === revealed) {
                  const newText = el.dataset.fullText.substring(0, elIndex + 1);
                  el.textContent = newText;
                  el.dataset.revealed = (elIndex + 1).toString();
                  el.classList.add('revealed');
                }
                break;
              }
              charCount += elLength;
            }

            // Position cursor
            for (const el of elements) {
              const elLength = el.dataset.fullText.length;
              if (index < charCount + elLength) {
                cursor.parentNode.insertBefore(cursor, el.nextSibling);
                break;
              }
              charCount += elLength;
            }

            index++;
            requestAnimationFrame(() => setTimeout(type, speed));
          }
        }

        setTimeout(type, 500);
      }
    </script>
  </body>
</html>
