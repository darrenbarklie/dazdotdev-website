---
import HtmlHead from "../components/_globals/HtmlHead.astro";
import Header from "../components/_globals/header/Header.astro";
import Footer from "../components/_globals/footer/Footer.astro";

export interface Props {
  content: {
    title: string;
    date: string;
    version: string;
  };
}

const {
  content: { title, date, version },
} = Astro.props as Props;

const objectDate = new Date(date);
const [day, month, year] = [
  objectDate.getDate(),
  objectDate.toLocaleString("default", { month: "long" }),
  objectDate.getFullYear(),
];
---

<!DOCTYPE html>
<html lang="en">
  <HtmlHead title={title} />

  <body>
    <Header />

    <div class="terminal-container outer">
      <article class="prose prose-base">
        <header box-="square" class="p-4 mb-8">
          <div class="mb-2">
            <span style="color: var(--foreground0);">$ cat</span>
            <span class="ml-2" style="color: var(--foreground2);">./{title.toLowerCase().replace(/\s+/g, '-')}</span>
          </div>
          <h1 class="sr-only">{title}</h1>
          <div class="text-sm" style="color: var(--foreground2);">
            <span style="color: var(--foreground1);">#</span> Last updated: {day} {month} {year}
            <span class="mx-2">|</span>
            v{version}
          </div>
        </header>

        <slot />
      </article>
    </div>

    <Footer />
  </body>
</html>
